# DOMAIN AND DNS CONFIGURATION
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@provider.com
DYNU_API_KEY=your_dynu_api_key

# DOCKER CONFIGURATION
DOCKER_API_VERSION=1.40

# AUTHELIA SECURITY SECRETS
# Generate these using: openssl rand -hex 64
AUTHELIA_SESSION_SECRET=session_secret_hex
AUTHELIA_STORAGE_ENCRYPTION_KEY=storage_encryption_key_hex
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=jwt_secret_hex
